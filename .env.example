# live | dry_run | auto — auto = dry_run when no GROQ_API_KEY (and no GEMINI_API_KEY if using Gemini only)
LLM_MODE=auto

# Provider: groq | gemini | auto — auto prefers Groq when GROQ_API_KEY is set
LLM_PROVIDER=auto

# Groq (recommended): https://console.groq.com/keys — generous free tier
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: only if LLM_PROVIDER=gemini or auto with no Groq key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pm_agents
