# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Docker Hub (for docker-compose.hub.yml) ───────────────────────────────────
DOCKERHUB_USERNAME=your_dockerhub_username
AGENTS_IMAGE_TAG=latest
AGENTS_PORT=8000

# ── Database (same DB as AgileAi — agents + business schemas) ─────────────────
# Local Postgres on host:
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@host.docker.internal:5432/agileai
# Postgres in Docker network (root docker-compose.yml):
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@postgres:5432/agileai
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/agileai

# ── LLM ───────────────────────────────────────────────────────────────────────
# Recommended for deployment: groq (no GPU required)
LLM_PROVIDER=groq
LLM_MODE=live
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: local Ollama (use docker compose --profile ollama)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3
# OLLAMA_PORT=11434

LLM_MAX_RETRIES=5
LLM_INITIAL_BACKOFF=1.0
LLM_MAX_BACKOFF=60.0
