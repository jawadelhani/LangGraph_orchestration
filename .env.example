# live = call Gemini | dry_run = no API (deterministic pipeline, good when quota hits 429)
# auto = dry_run if GEMINI_API_KEY is empty, else live
LLM_MODE=live

GEMINI_API_KEY=
# Free tier is often tighter on gemini-2.0-flash; 1.5-flash is the default in config.py
GEMINI_MODEL=gemini-1.5-flash

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pm_agents
